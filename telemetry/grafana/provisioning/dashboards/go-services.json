{
  "id": null,
  "uid": "go-services",
  "title": "Go Services",
  "description": "API Gateway, Media Service, and Message Consumer — per-service HTTP and Kafka metrics",
  "tags": ["go", "services", "api-gateway", "media-service", "message-consumer"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "API Gateway",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "API Gateway — Request Rate by Route",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (http_route, http_request_method) (rate(http_server_request_duration_seconds_count{otel_scope_name=\"api-gateway\"}[5m]))",
          "legendFormat": "{{http_request_method}} {{http_route}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "heatmap",
      "title": "API Gateway — Request Duration Distribution",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s" },
        "color": {
          "scheme": "Oranges",
          "exponent": 0.5,
          "mode": "scheme"
        },
        "tooltip": { "show": true, "yHistogram": false }
      },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (le) (rate(http_server_request_duration_seconds_bucket{otel_scope_name=\"api-gateway\"}[5m]))",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "API Gateway — Kafka Produce Rate by Topic",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (topic) (rate(kafka_producer_messages_total{otel_scope_name=\"api-gateway\"}[5m]))",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "API Gateway — Error Rate %",
      "description": "Percentage of requests returning 5xx status codes",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_request_duration_seconds_count{otel_scope_name=\"api-gateway\", http_response_status_code=~\"5..\"}[5m])) / sum(rate(http_server_request_duration_seconds_count{otel_scope_name=\"api-gateway\"}[5m]))",
          "legendFormat": "Error Rate"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Media Service",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Media Service — Webhook Request Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (http_route, http_response_status_code) (rate(http_server_request_duration_seconds_count{otel_scope_name=\"media-service\"}[5m]))",
          "legendFormat": "{{http_route}} ({{http_response_status_code}})"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Media Service — Kafka Consumer Messages Rate by Topic",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 18 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (topic) (rate(kafka_consumer_messages_total{otel_scope_name=\"media-service\"}[5m]))",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Media Service — Kafka Consumer Errors by Topic",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 18 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (topic) (rate(kafka_consumer_errors_total{otel_scope_name=\"media-service\"}[5m]))",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Message Consumer",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Message Consumer — Kafka Messages Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 27 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (topic) (rate(kafka_consumer_messages_total{otel_scope_name=\"message-consumer\"}[5m]))",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Message Consumer — Consumer Errors Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 27 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (topic) (rate(kafka_consumer_errors_total{otel_scope_name=\"message-consumer\"}[5m]))",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Message Consumer — Total Messages Processed",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 27 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(kafka_consumer_messages_total{otel_scope_name=\"message-consumer\"})",
          "legendFormat": "Total Processed"
        }
      ]
    }
  ]
}
