{
  "id": null,
  "uid": "media-saga",
  "title": "Media Saga Pipeline",
  "description": "Upload funnel, saga health, DLQ rates, and Flink processor metrics for the media upload/delete lifecycle",
  "tags": ["media", "saga", "flink", "pipeline"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Upload Funnel",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Upload Intents Rate",
      "description": "Rate of new upload intent events produced to internal.media.upload.intent",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(kafka_producer_messages_total{topic=\"internal.media.upload.intent\"}[5m]))",
          "legendFormat": "Intents/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Approved Rate",
      "description": "Rate of uploads approved (credit check passed) on public.media.upload.approved",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(kafka_consumer_messages_total{topic=\"public.media.upload.approved\"}[5m]))",
          "legendFormat": "Approved/s"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Confirmed Rate",
      "description": "Rate of uploads successfully confirmed (file moved to permanent storage) on public.media.upload.confirmed",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(kafka_consumer_messages_total{topic=\"public.media.upload.confirmed\"}[5m]))",
          "legendFormat": "Confirmed/s"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "DLQ Rate (Upload Dead-Letter)",
      "description": "Rate of uploads reaching the dead-letter queue — these require ops intervention",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.001 },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(kafka_consumer_messages_total{topic=\"internal.media.upload.dead-letter\"}[5m]))",
          "legendFormat": "DLQ/s"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Saga Health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Upload Retry Rate",
      "description": "Messages entering the upload retry loop (internal.media.upload.retry). Sustained nonzero = upstream issue.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(kafka_consumer_messages_total{topic=\"internal.media.upload.retry\"}[5m]))",
          "legendFormat": "Upload Retries/s"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Expired Uploads Rate",
      "description": "Rate of upload URLs expiring without a MinIO confirmation (public.media.expired.events)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(kafka_consumer_messages_total{topic=\"public.media.expired.events\"}[5m]))",
          "legendFormat": "Expired/s"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Delete Retry Rate",
      "description": "Rate of delete operations entering the retry loop (internal.media.delete.retry). Sustained = MinIO unreachable.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(kafka_consumer_messages_total{topic=\"internal.media.delete.retry\"}[5m]))",
          "legendFormat": "Delete Retries/s"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Flink Processors",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Flink Job Uptime by Job",
      "description": "Uptime of each Flink job in milliseconds. Zero means the job is down.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "flink_jobmanager_job_uptime",
          "legendFormat": "{{job_name}}"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Flink Operator Records Per Second",
      "description": "Number of records processed per second by each Flink task operator",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "rps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (task_name, job_name) (flink_taskmanager_job_task_numRecordsInPerSecond)",
          "legendFormat": "{{job_name}} / {{task_name}} (in)"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (task_name, job_name) (flink_taskmanager_job_task_numRecordsOutPerSecond)",
          "legendFormat": "{{job_name}} / {{task_name}} (out)"
        }
      ]
    }
  ]
}
