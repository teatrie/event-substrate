{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Replace",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/enforce-tdd.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Replace",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/run-tests.sh"
          }
        ]
      }
    ]
  }
}