FROM python:3.12-slim
ARG TARGETARCH
RUN apt-get update && apt-get install -y --no-install-recommends curl nodejs npm && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir yamllint sqlfluff
RUN npm install -g markdownlint-cli2 @probelabs/maid
RUN curl -sSL https://github.com/yannh/kubeconform/releases/download/v0.7.0/kubeconform-linux-${TARGETARCH}.tar.gz | tar xz -C /usr/local/bin/
RUN curl -sSL https://get.helm.sh/helm-v4.1.1-linux-${TARGETARCH}.tar.gz | tar xz --strip-components=1 -C /usr/local/bin/ linux-${TARGETARCH}/helm
WORKDIR /workspace
