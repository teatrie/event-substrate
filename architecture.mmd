graph TD
    %% Define styles for different components
    classDef frontend fill:#3b82f6,color:#fff,stroke:#1d4ed8,stroke-width:2px
    classDef gateway fill:#10b981,color:#fff,stroke:#047857,stroke-width:2px
    classDef broker fill:#ef4444,color:#fff,stroke:#b91c1c,stroke-width:2px
    classDef stream fill:#f59e0b,color:#fff,stroke:#b45309,stroke-width:2px
    classDef db fill:#8b5cf6,color:#fff,stroke:#6d28d9,stroke-width:2px
    classDef olap fill:#f97316,color:#fff,stroke:#c2410c,stroke-width:2px
    classDef registry fill:#64748b,color:#fff,stroke:#334155,stroke-width:2px
    classDef telemetry fill:#ec4899,color:#fff,stroke:#be185d,stroke-width:2px
    classDef auth fill:#dc2626,color:#fff,stroke:#991b1b,stroke-width:3px
    classDef mediaservice fill:#06b6d4,color:#fff,stroke:#0891b2,stroke-width:2px

    subgraph "User Layer"
        WebUI["Vite Frontend"]:::frontend
    end

    subgraph "Auth & Core Operations"
        Supabase[("Supabase\nPostgreSQL & Auth")]:::db
        UserNotifs[("user_notifications\n(Unified Egress)")]:::db
        CreditLedger[("credit_ledger\n(Append-Only)")]:::db
        CreditView["user_credit_balances\n(SUM View)"]:::db
        MediaFiles[("media_files\n(File Metadata)")]:::db
    end

    WebUI -.->|"1. Authentication"| Supabase
    Supabase -->|"2. pg_net webhooks\nPOST /webhooks/{topic}\n(X-Webhook-Secret)"| API
    WebUI -->|"3. Direct Client Ingress\nPOST /api/v1/events/{topic}\n(JWT: HS256 + ES256)"| API
    UserNotifs -.->|"Supabase Realtime\n(Single Subscription)"| WebUI
    API -.->|"Fetch JWKS\n(ES256 Public Key)"| Supabase

    subgraph "Kubernetes: go-microservices Namespace"
        API["Go API Gateway\n(api-gateway)"]:::gateway
        ConfigMap["ConfigMap\n(routes.yaml)"]:::registry
        GoMessageConsumer["Go Consumer:\nmessage-consumer"]:::stream
        MediaService["Go Consumer:\nmedia-service\n(🔑 media-service)"]:::mediaservice
        KEDA["KEDA Autoscaler\n(ScaledObject)"]:::telemetry
    end
    API <-->|"Fetch Avro Schemas"| SchemaReg
    ConfigMap -.->|"fsnotify\n(Zero-Downtime Hot-Reload)"| API
    KEDA -.->|"Watch Kafka Lag\n(Threshold: 5)"| TopicMessage
    KEDA -->|"Auto-Scale Pods"| GoMessageConsumer

    subgraph "Data Lake & Object Storage"
        Nessie["Project Nessie\n(REST Catalog)"]:::registry
        MinIO[("MinIO\n(S3 Object Storage)")]:::db
        MediaBucket[("MinIO: media-uploads\n(Claim Check Store)\n24h lifecycle policy")]:::db
    end

    subgraph "Message Broker (Redpanda · SASL/SCRAM-SHA-256)"
        Redpanda["Redpanda Broker\n(enable_sasl: true)"]:::broker
        AuthInit["redpanda-auth-init\n(Bootstrap Users & ACLs)"]:::auth
        SchemaReg["Schema Registry\n🔑 schema-admin"]:::registry
        subgraph "Public Topics (public.*)"
            TopicLogin("public.identity.login.events"):::broker
            TopicSignup("public.identity.signup.events"):::broker
            TopicSignout("public.identity.signout.events"):::broker
            TopicMessage("public.user.message.events"):::broker
            TopicMediaUpload("public.media.upload.events"):::broker
            TopicMediaDownload("public.media.download.events"):::broker
            TopicMediaDelete("public.media.delete.events"):::broker
            TopicUploadApproved("public.media.upload.approved"):::broker
            TopicUploadRejected("public.media.upload.rejected"):::broker
            TopicUploadSigned("public.media.upload.signed"):::broker
            TopicExpired("public.media.expired.events"):::broker
            TopicDownloadSigned("public.media.download.signed"):::broker
            TopicDownloadRejected("public.media.download.rejected"):::broker
            TopicDeleteRejected("public.media.delete.rejected"):::broker
        end
        subgraph "Internal Topics (internal.*)"
            TopicUnified("internal.platform.unified.events"):::broker
            TopicPy("internal.identity.login.echo"):::broker
            TopicUploadIntent("internal.media.upload.intent"):::broker
            TopicDownloadIntent("internal.media.download.intent"):::broker
            TopicDeleteIntent("internal.media.delete.intent"):::broker
        end
    end

    %% Auth bootstrap chain
    AuthInit -.->|"Admin API :9644\nCreate SCRAM Users + ACLs"| SchemaReg

    %% Data entering the broker (SASL: api-gateway — Write public.*, Write internal.media.*)
    API -->|"🔑 api-gateway\nProduce Avro"| TopicLogin
    API -->|"🔑 api-gateway\nProduce Avro"| TopicSignup
    API -->|"🔑 api-gateway\nProduce Avro"| TopicSignout
    API -->|"🔑 api-gateway\nProduce Avro"| TopicMessage

    subgraph "Kubernetes: default Namespace"
        subgraph "Stream Processing Pipeline (🔑 flink-processor)"
            FlinkLogin["Flink SQL:\nlogin_events_processor"]:::stream
            FlinkSignup["Flink SQL:\nsignup_events_processor"]:::stream
            FlinkSignout["Flink SQL:\nsignout_events_processor"]:::stream
            FlinkUnion["Flink SQL:\nunified_events_processor"]:::stream
            FlinkCredits["Flink SQL:\ncredit_balance_processor"]:::stream
            FlinkMediaNotifs["Flink SQL:\nmedia_notification_processor"]:::stream
            PyFlinkEcho["PyFlink:\necho_processor"]:::stream
            PyFlinkCreditCheck["PyFlink:\ncredit_check_processor\n(Atomic SQL)"]:::stream
            PyFlinkTTL["PyFlink:\nttl_expiry_processor\n(KeyedCoProcessFunction)"]:::stream
        end
    end

    %% Routing to processors (SASL: flink-processor — Read public.*, Read/Write internal.*)
    TopicLogin -->|"Consume Avro"| FlinkLogin
    TopicSignup -->|"Consume Avro"| FlinkSignup
    TopicSignout -->|"Consume Avro"| FlinkSignout

    TopicLogin -->|"Consume Avro"| FlinkUnion
    TopicSignup -->|"Consume Avro"| FlinkUnion
    TopicSignout -->|"Consume Avro"| FlinkUnion

    TopicLogin -->|"Consume Avro"| PyFlinkEcho

    TopicMessage -->|"🔑 message-consumer\ntwmb/franz-go"| GoMessageConsumer

    %% Output from processors
    FlinkUnion -->|"UNION ALL\nProduce unified Avro"| TopicUnified
    PyFlinkEcho -->|"Produce Avro"| TopicPy

    %% Iceberg Materialization (Tiered Storage)
    TopicLogin -.->|"Tiered Storage\nMaterialize Parquet"| Nessie
    TopicSignup -.->|"Tiered Storage\nMaterialize Parquet"| Nessie
    TopicSignout -.->|"Tiered Storage\nMaterialize Parquet"| Nessie
    TopicUnified -.->|"Tiered Storage\nMaterialize Parquet"| Nessie
    TopicPy -.->|"Tiered Storage\nMaterialize Parquet"| Nessie
    TopicMessage -.->|"Tiered Storage\nMaterialize Parquet"| Nessie
    TopicMediaUpload -.->|"Tiered Storage\nMaterialize Parquet"| Nessie
    TopicMediaDownload -.->|"Tiered Storage\nMaterialize Parquet"| Nessie
    TopicMediaDelete -.->|"Tiered Storage\nMaterialize Parquet"| Nessie

    Nessie -->|"Manage Metadata & Data"| MinIO

    %% Processors write to unified notifications only
    FlinkLogin -->|"INSERT JDBC\n(identity.login)"| UserNotifs
    FlinkSignup -->|"INSERT JDBC\n(identity.signup)"| UserNotifs
    FlinkSignout -->|"INSERT JDBC\n(identity.signout)"| UserNotifs
    GoMessageConsumer -->|"lib/pq INSERT\n(user.message)"| UserNotifs

    %% Credit balance processor (consumes signup + expired events)
    TopicSignup -->|"Consume Avro"| FlinkCredits
    TopicMediaUpload -->|"Consume Avro"| FlinkCredits
    TopicExpired -->|"Consume Avro"| FlinkCredits
    FlinkCredits -->|"INSERT JDBC\n(+2 signup / -1 upload\n+1 expired refund)"| CreditLedger
    FlinkCredits -->|"INSERT JDBC\n(file metadata)"| MediaFiles
    FlinkCredits -->|"INSERT JDBC\n(credit.balance_changed)"| UserNotifs
    CreditLedger -.->|"SUM(amount)"| CreditView

    %% ═══════════════════════════════════════════════════════════
    %% Upload Saga (fully async event-driven media pipeline)
    %% ═══════════════════════════════════════════════════════════

    %% Step 1: Frontend submits intent → API Gateway produces to internal topic
    WebUI -->|"4. POST /api/v1/media/upload-intent\n(JWT) → 202 {request_id}"| API
    API -->|"🔑 api-gateway\nProduce Avro\n(UploadIntent)"| TopicUploadIntent

    %% Step 2: PyFlink credit check (atomic SQL: check + deduct in one query)
    TopicUploadIntent -->|"Consume Avro"| PyFlinkCreditCheck
    PyFlinkCreditCheck -->|"Approved\n(balance >= 1)"| TopicUploadApproved
    PyFlinkCreditCheck -->|"Rejected\n(insufficient credits)"| TopicUploadRejected

    %% Step 3: Media Service generates presigned URL
    TopicUploadApproved -->|"🔑 media-service\nConsume Avro"| MediaService
    MediaService -->|"Presigned PUT URL\nProduce Avro"| TopicUploadSigned

    %% Step 4: Flink notification processor routes all media events to user_notifications
    TopicUploadSigned -->|"Consume Avro"| FlinkMediaNotifs
    TopicUploadRejected -->|"Consume Avro"| FlinkMediaNotifs
    TopicMediaUpload -->|"Consume Avro"| FlinkMediaNotifs
    TopicExpired -->|"Consume Avro"| FlinkMediaNotifs
    TopicDownloadSigned -->|"Consume Avro"| FlinkMediaNotifs
    TopicDownloadRejected -->|"Consume Avro"| FlinkMediaNotifs
    TopicMediaDelete -->|"Consume Avro"| FlinkMediaNotifs
    TopicDeleteRejected -->|"Consume Avro"| FlinkMediaNotifs
    FlinkMediaNotifs -->|"INSERT JDBC\n(media.* notifications)"| UserNotifs

    %% Step 5: Frontend receives presigned URL via Realtime → uploads directly
    WebUI -->|"5. PUT file (browser-direct)\n(presigned URL + CORS)"| MediaBucket

    %% Step 6: MinIO webhook → upload completion event
    MediaBucket -->|"6. Webhook notification\nPOST /webhooks/media-upload"| API
    API -->|"🔑 api-gateway\nProduce Avro\n(NewFileUploaded)"| TopicMediaUpload

    %% Step 7: TTL expiry processor (dual-stream, processing-time timer)
    TopicUploadSigned -->|"Consume Avro\n(arm timer)"| PyFlinkTTL
    TopicMediaUpload -->|"Consume Avro\n(mark completed)"| PyFlinkTTL
    PyFlinkTTL -->|"Timer fired\nno upload"| TopicExpired

    %% Step 8: Expired cleanup (best-effort MinIO removal)
    TopicExpired -->|"🔑 media-service\nConsume Avro"| MediaService
    MediaService -->|"RemoveObject\n(best-effort)"| MediaBucket

    %% ═══════════════════════════════════════════════════════════
    %% Download Saga (async intent → presigned GET URL)
    %% ═══════════════════════════════════════════════════════════
    WebUI -->|"POST /api/v1/media/download-intent\n(JWT) → 202 {request_id}"| API
    API -->|"🔑 api-gateway\nProduce Avro\n(DownloadIntent)"| TopicDownloadIntent
    TopicDownloadIntent -->|"🔑 media-service\nConsume Avro"| MediaService
    MediaService -->|"Ownership check\n+ Presigned GET URL"| TopicDownloadSigned
    MediaService -->|"Not found"| TopicDownloadRejected
    MediaService -->|"Query file metadata"| MediaFiles
    WebUI -.->|"GET file (browser-direct)\n(presigned URL)"| MediaBucket

    %% ═══════════════════════════════════════════════════════════
    %% Delete Saga (async intent → soft-delete + MinIO removal)
    %% ═══════════════════════════════════════════════════════════
    WebUI -->|"POST /api/v1/media/delete-intent\n(JWT) → 202 {request_id}"| API
    API -->|"🔑 api-gateway\nProduce Avro\n(DeleteIntent)"| TopicDeleteIntent
    TopicDeleteIntent -->|"🔑 media-service\nConsume Avro"| MediaService
    MediaService -->|"Ownership + RemoveObject\n+ SoftDelete"| TopicMediaDelete
    MediaService -->|"Not found / error"| TopicDeleteRejected
    MediaService -->|"UPDATE status='deleted'"| MediaFiles
    MediaService -->|"RemoveObject"| MediaBucket

    subgraph "Real-Time OLAP (🔑 clickhouse-consumer)"
        CHKafka["Kafka Table Engine"]:::olap
        CHMV["Materialized View"]:::olap
        CHMergeTree[("ReplacingMergeTree Table\n(unified_events)")]:::olap

        CHKafka -->|"Pipe records"| CHMV
        CHMV -->|"Insert"| CHMergeTree
    end

    %% Into Clickhouse (SASL: clickhouse-consumer — Read internal.*)
    TopicUnified -->|"🔑 clickhouse-consumer\nConsume Avro"| CHKafka
    CHKafka <-->|"Fetch Schemas"| SchemaReg

    subgraph "Observability Stack"
        OTel["OpenTelemetry Collector"]:::telemetry
        Prometheus[("Prometheus")]:::telemetry
        Loki[("Loki (Logs)")]:::telemetry
        Jaeger["Jaeger (Tracing)"]:::telemetry
        Grafana["Grafana Dashboard"]:::telemetry

        OTel -->|"Metrics"| Prometheus
        OTel -->|"Logs"| Loki
        OTel -->|"Traces"| Jaeger
        Prometheus --> Grafana
        Loki --> Grafana
        Jaeger --> Grafana
    end

    %% Telemetry reporting
    API -.->|"OTLP Metrics"| OTel
    FlinkLogin -.->|"StatsD"| OTel
    FlinkSignup -.->|"StatsD"| OTel
    FlinkSignout -.->|"StatsD"| OTel
    FlinkUnion -.->|"StatsD"| OTel

    %% Bootstrap dependency chain
    AuthInit -.->|"depends_on\n(service_healthy)"| Redpanda
    SchemaReg -.->|"depends_on\n(auth-init completed)"| AuthInit
    CHKafka -.->|"depends_on"| Redpanda
    Redpanda -.->|"depends_on"| MinIO
    Redpanda -.->|"depends_on"| Nessie
